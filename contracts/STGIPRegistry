pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/security/Pausable.sol";

contract STGIPRegistry is Ownable, Pausable {

    struct Record {
        bytes32 recordHash;
        string cid;
        uint256 timestamp;
    }

    mapping(bytes32 => Record) public records;

    event RecordRegistered(bytes32 indexed id, string cid);

    constructor(address initialOwner) Ownable(initialOwner) {}

    function registerRecord(
        bytes32 id,
        bytes32 hash,
        string calldata cid
    ) external onlyOwner {
        require(records[id].timestamp == 0, "Already exists");

        records[id] = Record({
            recordHash: hash,
            cid: cid,
            timestamp: block.timestamp
        });

        emit RecordRegistered(id, cid);
    }

    function pause() external onlyOwner {
        _pause();
    }

    function unpause() external onlyOwner {
        _unpause();
    }
}
